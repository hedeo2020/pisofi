[Unit]
Description=PisoFi Orange Pi device agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/pisonet-agent -config /etc/pisonet-agent/config.json
Restart=always
RestartSec=5
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/pisonet-agent /etc/pisonet-agent

[Install]
WantedBy=multi-user.target
